# Copy to .env and adjust for your environment.

# Generate a new key for production: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production
DEBUG=True

# Comma-separated hostnames allowed to serve the app
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend origins allowed to call the API (CORS)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Needed in production when frontend is on another https domain
CSRF_TRUSTED_ORIGINS=

# Leave unset to use SQLite. In production set e.g.
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_URL=
